# Keep generated/runtime text deterministic across Windows, macOS, and Linux.
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary assets must never receive line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.wav binary
*.mp3 binary
*.ogg binary
